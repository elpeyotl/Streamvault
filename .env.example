# TMDB - Get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Supabase - Get from https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Hash sources
ZILEAN_API_URL=https://zilean.elfhosted.com
TORRENTIO_API_URL=https://torrentio.strem.fun

# OpenSubtitles - Get from https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=your_opensubtitles_api_key

# Encryption key for RD tokens in DB (generate with: openssl rand -hex 16)
RD_TOKEN_ENCRYPTION_KEY=generate_a_random_32_char_string
